.shell {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8eefb 0%, #f4f6fb 220rpx);
}

.scroll {
  max-height: 100vh;
  padding: 24rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.muted {
  color: #64748b;
  font-size: 28rpx;
  padding: 48rpx;
}

.hero {
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.hero-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.45;
}

.empty {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  border: 2rpx dashed #e2e8f0;
}

.day-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 28rpx 0 18rpx;
}

.day-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #cbd5e1, transparent);
}

.day-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
  white-space: nowrap;
}

.tx-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
}

.tx-row-flex {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tx-left {
  flex: 1;
  min-width: 0;
}

.btn-edit {
  flex-shrink: 0;
  margin-top: 4rpx;
  background: #eef2ff !important;
  color: #4f46e5 !important;
  font-weight: 600;
}

.tx-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
}

.tx-cat {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  flex: 1;
}

.tx-amt {
  font-size: 34rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.tx-amt.ex {
  color: #dc2626;
}

.tx-amt.in {
  color: #059669;
}

.tx-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.chip {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
}

.tx-time {
  font-size: 24rpx;
  color: #64748b;
}

.tx-clock {
  font-size: 24rpx;
  color: #94a3b8;
  font-variant-numeric: tabular-nums;
}

.tx-row2 {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #475569;
}

.tx-fund::before {
  content: '账户 · ';
  color: #94a3b8;
}

.tx-note {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #475569;
}

.tx-tags {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.bottom-space {
  height: 40rpx;
}
