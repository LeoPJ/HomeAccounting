<wxs module="util">
var contains = function(ids, id) {
  id = +id;
  var arr = ids || [];
  for (var i = 0; i < arr.length; i++) {
    if (+arr[i] === id) return true;
  }
  return false;
};
module.exports.contains = contains;
</wxs>

<view class="shell">
  <view wx:if="{{loading}}" class="muted">加载中…</view>
  <scroll-view wx:else scroll-y class="scroll">
    <view class="hero-tip">在此修改后保存，将同步到账本流水列表</view>

    <view class="seg">
      <button size="mini" class="seg-i {{type === 'EXPENSE' ? 'on' : ''}}" bindtap="onTypeExpense">支出</button>
      <button size="mini" class="seg-i {{type === 'INCOME' ? 'on' : ''}}" bindtap="onTypeIncome">收入</button>
    </view>

    <view class="field">
      <text class="label">账本</text>
      <picker mode="selector" range="{{ledgers}}" range-key="name" value="{{ledgerIdx}}" bindchange="onLedgerChange">
        <view class="picker">{{ledgers.length ? ledgers[ledgerIdx].name : '无'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">资金账户</text>
      <picker mode="selector" range="{{fundPickerRange}}" value="{{fundIdx}}" bindchange="onFundChange">
        <view class="picker">{{fundPickerRange[fundIdx]}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">分类</text>
      <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIdx}}" bindchange="onCategoryChange">
        <view class="picker">{{categories.length ? categories[categoryIdx].name : '无'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">金额</text>
      <input class="input" type="digit" placeholder="0.00" value="{{amount}}" bindinput="onAmount" />
    </view>

    <view class="field">
      <text class="label">日期</text>
      <picker mode="date" value="{{dateStr}}" bindchange="onDateChange">
        <view class="picker">{{dateStr}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">时间</text>
      <picker mode="time" value="{{timeStr}}" bindchange="onTimeChange">
        <view class="picker">{{timeStr}}</view>
      </picker>
    </view>

    <view class="field block">
      <text class="label">标签（多选）</text>
      <block wx:for="{{[tagGroupKey]}}" wx:key="*this">
        <checkbox-group bindchange="onTagsChange">
          <label wx:for="{{tags}}" wx:key="id" class="tag-row">
            <checkbox value="{{item.id}}" checked="{{util.contains(selectedTagIds, item.id)}}" />
            <text>{{item.name}}</text>
          </label>
        </checkbox-group>
      </block>
    </view>

    <view class="field">
      <text class="label">备注</text>
      <input class="input" placeholder="可选" value="{{note}}" bindinput="onNote" />
    </view>

    <button type="primary" class="btn-save" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">保存修改</button>
    <button class="btn-del" bindtap="onDelete" loading="{{deleting}}" disabled="{{deleting}}">删除本条流水</button>
  </scroll-view>
</view>
