.shell {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8eefb 0%, #f4f6fb 220rpx);
}

.muted {
  color: #64748b;
  font-size: 28rpx;
  padding: 48rpx;
}

.scroll {
  max-height: 100vh;
  padding: 24rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.seg {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.seg-i {
  flex: 1;
  border-radius: 14rpx !important;
  font-weight: 600;
  background: #fff !important;
  color: #475569 !important;
  border: 2rpx solid #e2e8f0 !important;
}

.seg-i.on {
  background: linear-gradient(135deg, #4f46e5, #4338ca) !important;
  color: #fff !important;
  border-color: transparent !important;
}

.field {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 18rpx 22rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.04);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
}

.field.block {
  flex-direction: column;
  align-items: flex-start;
}

.label {
  width: 176rpx;
  font-size: 28rpx;
  color: #475569;
  flex-shrink: 0;
}

.picker {
  flex: 1;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #0f172a;
}

.input {
  flex: 1;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.tag-row {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
  padding: 6rpx 0;
}

.tag-row text {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #334155;
}

.btn-save {
  margin-top: 28rpx;
  border-radius: 16rpx !important;
  font-weight: 600;
  background: linear-gradient(135deg, #4f46e5, #4338ca) !important;
}
