.shell {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8eefb 0%, #f4f6fb 220rpx);
}

.page-inner {
  padding: 24rpx 28rpx 48rpx;
  box-sizing: border-box;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.muted {
  color: #8b9199;
  font-size: 28rpx;
  padding: 48rpx;
}

.muted.pad {
  padding: 16rpx 0 32rpx;
}

.hero {
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1d24;
}

.hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.45;
}

.btn-new {
  margin-bottom: 24rpx;
  border-radius: 16rpx !important;
  font-weight: 600;
  background: linear-gradient(135deg, #4f46e5, #4338ca) !important;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(37, 99, 235, 0.07);
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.picker {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: #f3f5f9;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1d24;
  margin: 12rpx 0 16rpx;
}

.empty {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  font-size: 26rpx;
  color: #8b9199;
  line-height: 1.55;
  margin-bottom: 24rpx;
  border: 2rpx dashed #e2e8f0;
}

.tpl-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
}

.tpl-main {
  margin-bottom: 16rpx;
}

.tpl-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1d24;
}

.tpl-id {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.tpl-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.btn-soft {
  background: #f1f5f9 !important;
  color: #475569 !important;
}

.btn-soft.danger {
  color: #dc2626 !important;
  background: #fef2f2 !important;
}

.row-card {
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #eef2f6;
}

.summary-line {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.45;
}

.section-title.sub {
  font-size: 26rpx;
  margin-top: 8rpx;
}

.pie-section {
  margin: 24rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(37, 99, 235, 0.07);
}

.pie-title {
  margin-bottom: 8rpx;
}

/* 固定占位 + 裁剪，避免原生 canvas 在滚动容器中错位到底部 Tab */
.pie-canvas-box {
  position: relative;
  width: 480rpx;
  height: 480rpx;
  margin: 16rpx auto;
  overflow: hidden;
  border-radius: 16rpx;
  background: #fafbfc;
}

.pie-canvas {
  width: 480rpx;
  height: 480rpx;
  display: block;
}

.pie-legend {
  margin-top: 16rpx;
}

.pie-leg-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
  font-size: 24rpx;
}

.pie-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.pie-leg-t {
  flex: 1;
  color: #475569;
}

.pie-leg-v {
  font-weight: 600;
  color: #0f172a;
  font-variant-numeric: tabular-nums;
}

.detail-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid #eef2f6;
  position: relative;
}

.detail-main {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.detail-cat {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.detail-amt {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  font-variant-numeric: tabular-nums;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.detail-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.detail-note {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.detail-edit {
  margin-top: 12rpx;
}

.bottom-space {
  height: 32rpx;
}
