.shell {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8eefb 0%, #f4f6fb 220rpx);
}

.scroll {
  max-height: 100vh;
  padding: 24rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.muted {
  color: #8b9199;
  font-size: 28rpx;
  padding: 48rpx;
}

.hero {
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1d24;
}

.hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.45;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1d24;
  margin: 28rpx 0 16rpx;
}

.section-title:first-of-type {
  margin-top: 8rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(37, 99, 235, 0.07);
}

.card.tight {
  padding: 20rpx 24rpx;
}

.card-hint {
  display: block;
  font-size: 24rpx;
  color: #8b9199;
  line-height: 1.45;
  margin-bottom: 20rpx;
}

.field-col {
  margin-bottom: 20rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.input {
  padding: 20rpx 24rpx;
  background: #f3f5f9;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.input.full {
  width: 100%;
  box-sizing: border-box;
}

.btn-block {
  margin-top: 8rpx;
  border-radius: 16rpx !important;
  font-weight: 600;
  background: linear-gradient(135deg, #2563eb, #1d4ed8) !important;
}

.empty.small {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
  border: 2rpx dashed #e2e8f0;
}

.list-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.list-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1d24;
}

.list-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.seg {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.seg-btn {
  flex: 1;
  border-radius: 14rpx !important;
  font-weight: 600;
  background: #fff !important;
  color: #475569 !important;
  border: 2rpx solid #e2e8f0 !important;
}

.seg-btn.seg-on {
  background: linear-gradient(135deg, #2563eb, #1d4ed8) !important;
  color: #fff !important;
  border-color: transparent !important;
}

.add-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.flex1 {
  flex: 1;
}

.sub-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin: 16rpx 0 8rpx;
}

.list-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 24rpx;
  margin-bottom: 10rpx;
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #eef2f6;
}

.list-row-text {
  font-size: 28rpx;
  color: #334155;
}

.btn-danger-soft {
  background: #fef2f2 !important;
  color: #dc2626 !important;
}

.bottom-space {
  height: 32rpx;
}
