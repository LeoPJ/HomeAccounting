# 复制到服务器（如 /etc/home-accounting.env），chmod 600，并在 systemd 里引用 EnvironmentFile。
# 与 application.yml 中的 ${VAR:default} 对应，未列出的项使用 yml 默认值即可。

SERVER_PORT=8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=homeaccounting
DB_PASSWORD=change-me

JWT_SECRET=change-me-long-random
JWT_EXPIRATION=7d

WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# 生产务必 false，且不要设置 dev-login-secret
DEV_LOGIN_ENABLED=false

# 若管理后台通过浏览器访问 API，可收紧为具体域名模式
APP_CORS_ORIGIN_PATTERNS=*
