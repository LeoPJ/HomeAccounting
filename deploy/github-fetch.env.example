# 复制到服务器（例如 /etc/home-accounting/github-fetch.env），chmod 600。
# 由 deploy/fetch-jar-from-github.sh 读取（脚本里可 source 此文件）。

# 经典 PAT：私有仓库需带 repo；或细粒度令牌：Actions → Read、Metadata → Read
export GITHUB_TOKEN='ghp_或_github_pat_开头的一串'

export GITHUB_OWNER='你的GitHub用户名或组织名'
export GITHUB_REPO='HomeAccounting'

# 与 build-jar.yml 成功运行所在分支一致，一般为 main
export GITHUB_BRANCH='main'

# 安装路径（脚本会把 jar 拷到这里）
export INSTALL_DIR='/opt/home-accounting'

# 装好后是否执行 systemctl restart（设为 0 表示只拷 jar 不重启）
export RESTART_SERVICE='1'
export SYSTEMD_UNIT='home-accounting'
